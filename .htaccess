# ----------------------------------------------------------------------
# | Browser Caching & Expire Headers                                    |
# ----------------------------------------------------------------------

ExpiresActive On
ExpiresDefault "access plus 1 month"

# CSS & JavaScript
ExpiresByType text/css "access plus 1 year"
ExpiresByType application/javascript "access plus 1 year"
ExpiresByType text/javascript "access plus 1 year"
ExpiresByType application/x-javascript "access plus 1 year"

# Images & Media
ExpiresByType image/jpeg "access plus 1 year"
ExpiresByType image/png "access plus 1 year"
ExpiresByType image/gif "access plus 1 year"
ExpiresByType image/webp "access plus 1 year"
ExpiresByType image/svg+xml "access plus 1 year"
ExpiresByType image/x-icon "access plus 1 year"
ExpiresByType image/vnd.microsoft.icon "access plus 1 year"

# Web Fonts
ExpiresByType font/woff "access plus 1 year"
ExpiresByType font/woff2 "access plus 1 year"
ExpiresByType application/font-woff "access plus 1 year"
ExpiresByType application/font-woff2 "access plus 1 year"
ExpiresByType application/vnd.ms-fontobject "access plus 1 year"
ExpiresByType font/opentype "access plus 1 year"
ExpiresByType font/ttf "access plus 1 year"
ExpiresByType application/x-font-ttf "access plus 1 year"

# ----------------------------------------------------------------------
# | Cache-Control Headers (Forced for LiteSpeed/Apache)                 |
# ----------------------------------------------------------------------

<FilesMatch "\.(css|js|txt|xml)$">
    Header always set Cache-Control "max-age=31536000, public"
</FilesMatch>
<FilesMatch "\.(gif|jpe?g|png|ico|svg|webp|woff2?|ttf|otf)$">
    Header always set Cache-Control "max-age=31536000, public"
</FilesMatch>

# ----------------------------------------------------------------------
# | Security Headers                                                    |
# ----------------------------------------------------------------------

# Prevent Clickjacking (Mitigate clickjacking with XFO)
Header always set X-Frame-Options "SAMEORIGIN"

# Prevent MIME sniffing (Mitigate MIME sniffing)
Header always set X-Content-Type-Options "nosniff"

# Cross-Origin Opener Policy (Mitigate COOP)
Header always set Cross-Origin-Opener-Policy "same-origin"

# Strict Transport Security (Force HTTPS)
Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

# Upgrade Insecure Requests CSP
Header always set Content-Security-Policy "upgrade-insecure-requests;"

# Referrer Policy
Header always set Referrer-Policy "strict-origin-when-cross-origin"

# Permissions Policy
Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"

